# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=conduit
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=conduit_db

# ─── NestJS API ───────────────────────────────────────
DATABASE_URL=postgresql://conduit:change_me_in_production@db:5432/conduit_db
JWT_SECRET=change_me_with_a_long_random_string_in_production
PORT=3001

# ─── Next.js Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── LMS (optionnel) ─────────────────────────────────
NEXT_PUBLIC_LMS_URL=https://ton-lms.com
